#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>
#include <stdbool.h>
#include <emscripten.h>

// ==================== LEXICAL ANALYSIS ====================

#define MAX_TOKENS 256
#define MAX_TOKEN_LEN 64
#define MAX_OUTPUT 8192

static char output_buffer[MAX_OUTPUT];

typedef enum {
    TOK_INT, TOK_FLOAT, TOK_CHAR, TOK_IF, TOK_ELSE, TOK_WHILE, TOK_RETURN,
    TOK_IDENTIFIER, TOK_NUMBER, TOK_FLOAT_LIT, TOK_CHAR_LIT, TOK_STRING_LIT,
    TOK_PLUS, TOK_MINUS, TOK_STAR, TOK_SLASH, TOK_ASSIGN,
    TOK_EQ, TOK_NEQ, TOK_LT, TOK_GT, TOK_LTE, TOK_GTE,
    TOK_LPAREN, TOK_RPAREN, TOK_LBRACE, TOK_RBRACE, TOK_SEMICOLON, TOK_COMMA,
    TOK_EOF, TOK_ERROR
} TokenType;

typedef struct {
    TokenType type;
    char value[MAX_TOKEN_LEN];
    int line;
    int col;
} Token;

static Token tokens[MAX_TOKENS];
static int token_count = 0;

const char* token_type_name(TokenType t) {
    switch(t) {
        case TOK_INT: return "KEYWORD_INT";
        case TOK_FLOAT: return "KEYWORD_FLOAT";
        case TOK_CHAR: return "KEYWORD_CHAR";
        case TOK_IF: return "KEYWORD_IF";
        case TOK_ELSE: return "KEYWORD_ELSE";
        case TOK_WHILE: return "KEYWORD_WHILE";
        case TOK_RETURN: return "KEYWORD_RETURN";
        case TOK_IDENTIFIER: return "IDENTIFIER";
        case TOK_NUMBER: return "INTEGER_LITERAL";
        case TOK_FLOAT_LIT: return "FLOAT_LITERAL";
        case TOK_CHAR_LIT: return "CHAR_LITERAL";
        case TOK_STRING_LIT: return "STRING_LITERAL";
        case TOK_PLUS: return "OPERATOR_PLUS";
        case TOK_MINUS: return "OPERATOR_MINUS";
        case TOK_STAR: return "OPERATOR_MULTIPLY";
        case TOK_SLASH: return "OPERATOR_DIVIDE";
        case TOK_ASSIGN: return "OPERATOR_ASSIGN";
        case TOK_EQ: return "OPERATOR_EQUAL";
        case TOK_NEQ: return "OPERATOR_NOT_EQUAL";
        case TOK_LT: return "OPERATOR_LESS";
        case TOK_GT: return "OPERATOR_GREATER";
        case TOK_LTE: return "OPERATOR_LESS_EQUAL";
        case TOK_GTE: return "OPERATOR_GREATER_EQUAL";
        case TOK_LPAREN: return "LEFT_PAREN";
        case TOK_RPAREN: return "RIGHT_PAREN";
        case TOK_LBRACE: return "LEFT_BRACE";
        case TOK_RBRACE: return "RIGHT_BRACE";
        case TOK_SEMICOLON: return "SEMICOLON";
        case TOK_COMMA: return "COMMA";
        case TOK_EOF: return "EOF";
        case TOK_ERROR: return "ERROR";
        default: return "UNKNOWN";
    }
}

TokenType check_keyword(const char* word) {
    if (strcmp(word, "int") == 0) return TOK_INT;
    if (strcmp(word, "float") == 0) return TOK_FLOAT;
    if (strcmp(word, "char") == 0) return TOK_CHAR;
    if (strcmp(word, "if") == 0) return TOK_IF;
    if (strcmp(word, "else") == 0) return TOK_ELSE;
    if (strcmp(word, "while") == 0) return TOK_WHILE;
    if (strcmp(word, "return") == 0) return TOK_RETURN;
    return TOK_IDENTIFIER;
}

void lexer(const char* input) {
    token_count = 0;
    int i = 0, line = 1, col = 1;
    int len = strlen(input);

    while (i < len && token_count < MAX_TOKENS - 1) {

        // Ignore C preprocessor directives like #include and #define
        if (input[i] == '#') {
            while (i < len && input[i] != '\n') {
                i++;
                col++;
            }
            continue;
        }

        // Ignore single-line comments //
        if (input[i] == '/' && i + 1 < len && input[i + 1] == '/') {
            while (i < len && input[i] != '\n') {
                i++;
                col++;
            }
            continue;
        }

        // Ignore multi-line comments /* */
        if (input[i] == '/' && i + 1 < len && input[i + 1] == '*') {
            i += 2;
            col += 2;

            while (i + 1 < len && !(input[i] == '*' && input[i + 1] == '/')) {
                if (input[i] == '\n') {
                    line++;
                    col = 1;
                } else {
                    col++;
                }
                i++;
            }

            if (i + 1 < len) {
                i += 2;
                col += 2;
            }

            continue;
        }

        // Skip whitespace
        while (i < len && (input[i] == ' ' || input[i] == '\t' || input[i] == '\n' || input[i] == '\r')) {
            if (input[i] == '\n') {
                line++;
                col = 1;
            } else {
                col++;
            }
            i++;
        }

        if (i >= len) break;

        Token* t = &tokens[token_count];
        t->line = line;
        t->col = col;

        // Identifiers and keywords
        if (isalpha(input[i]) || input[i] == '_') {
            int start = i;

            while (i < len && (isalnum(input[i]) || input[i] == '_')) {
                i++;
                col++;
            }

            int wlen = i - start;

            if (wlen >= MAX_TOKEN_LEN)
                wlen = MAX_TOKEN_LEN - 1;

            strncpy(t->value, input + start, wlen);
            t->value[wlen] = '\0';

            t->type = check_keyword(t->value);

            token_count++;
        }

        // Numbers
        else if (isdigit(input[i])) {
            int start = i;
            int has_dot = 0;

            while (i < len && (isdigit(input[i]) || (input[i] == '.' && !has_dot))) {
                if (input[i] == '.')
                    has_dot = 1;

                i++;
                col++;
            }

            int wlen = i - start;

            if (wlen >= MAX_TOKEN_LEN)
                wlen = MAX_TOKEN_LEN - 1;

            strncpy(t->value, input + start, wlen);
            t->value[wlen] = '\0';

            t->type = has_dot ? TOK_FLOAT_LIT : TOK_NUMBER;

            token_count++;
        }

        // String literals
        else if (input[i] == '"') {
            int start = i;

            i++;
            col++;

            while (i < len && input[i] != '"') {
                if (input[i] == '\n') {
                    line++;
                    col = 1;
                } else {
                    col++;
                }

                i++;
            }

            if (i < len) {
                i++;
                col++;
            }

            int wlen = i - start;

            if (wlen >= MAX_TOKEN_LEN)
                wlen = MAX_TOKEN_LEN - 1;

            strncpy(t->value, input + start, wlen);
            t->value[wlen] = '\0';

            t->type = TOK_STRING_LIT;

            token_count++;
        }

        // Char literals
        else if (input[i] == '\'') {
            int start = i;

            i++;
            col++;

            while (i < len && input[i] != '\'') {
                i++;
                col++;
            }

            if (i < len) {
                i++;
                col++;
            }

            int wlen = i - start;

            if (wlen >= MAX_TOKEN_LEN)
                wlen = MAX_TOKEN_LEN - 1;

            strncpy(t->value, input + start, wlen);
            t->value[wlen] = '\0';

            t->type = TOK_CHAR_LIT;

            token_count++;
        }

        // Operators and punctuation
        else {
            t->value[1] = '\0';
            t->value[0] = input[i];

            switch(input[i]) {
                case '+': t->type = TOK_PLUS; break;
                case '-': t->type = TOK_MINUS; break;
                case '*': t->type = TOK_STAR; break;
                case '/': t->type = TOK_SLASH; break;

                case '=':
                    if (i + 1 < len && input[i + 1] == '=') {
                        t->type = TOK_EQ;
                        t->value[1] = '=';
                        t->value[2] = '\0';
                        i++;
                        col++;
                    } else {
                        t->type = TOK_ASSIGN;
                    }
                    break;

                case '!':
                    if (i + 1 < len && input[i + 1] == '=') {
                        t->type = TOK_NEQ;
                        t->value[1] = '=';
                        t->value[2] = '\0';
                        i++;
                        col++;
                    } else {
                        t->type = TOK_ERROR;
                    }
                    break;

                case '<':
                    if (i + 1 < len && input[i + 1] == '=') {
                        t->type = TOK_LTE;
                        t->value[1] = '=';
                        t->value[2] = '\0';
                        i++;
                        col++;
                    } else {
                        t->type = TOK_LT;
                    }
                    break;

                case '>':
                    if (i + 1 < len && input[i + 1] == '=') {
                        t->type = TOK_GTE;
                        t->value[1] = '=';
                        t->value[2] = '\0';
                        i++;
                        col++;
                    } else {
                        t->type = TOK_GT;
                    }
                    break;

                case '(': t->type = TOK_LPAREN; break;
                case ')': t->type = TOK_RPAREN; break;
                case '{': t->type = TOK_LBRACE; break;
                case '}': t->type = TOK_RBRACE; break;
                case ';': t->type = TOK_SEMICOLON; break;
                case ',': t->type = TOK_COMMA; break;

                default:
                    t->type = TOK_ERROR;
                    break;
            }

            i++;
            col++;

            token_count++;
        }
    }

    // EOF Token
    tokens[token_count].type = TOK_EOF;
    strcpy(tokens[token_count].value, "EOF");
    tokens[token_count].line = line;
    tokens[token_count].col = col;

    token_count++;
}

// Strict C Architecture structural checker rule
bool verify_c_structure(const char* code, char* error_buf) {
    // 1. Search for macro directive token sequence containing standard stdio
    const char* include_loc = strstr(code, "#include");
    if (include_loc == NULL || strstr(include_loc, "<stdio.h>") == NULL) {
        strcpy(error_buf, "Strict Error: Missing global requirement #include <stdio.h> definition.");
        return false;
    }

    // 2. Search for valid C environment execution block signature 
    if (strstr(code, "main") == NULL) {
        strcpy(error_buf, "Strict Error: Target program must include an explicit main() entry loop context.");
        return false;
    }
    return true;
}

// ==================== SYNTAX ANALYSIS ====================

static int parse_pos;
static int parse_error;
static char parse_error_msg[256];

// Forward declarations
static void parse_expr(char* tree, int depth);
static void parse_term(char* tree, int depth);
static void parse_factor(char* tree, int depth);

static void indent(char* tree, int depth) {
    for (int i = 0; i < depth; i++) strcat(tree, "  ");
}

static Token* current_token() {
    if (parse_pos < token_count) return &tokens[parse_pos];
    return &tokens[token_count - 1];
}

static void advance() {
    if (parse_pos < token_count - 1) parse_pos++;
}

static int expect(TokenType type) {
    if (current_token()->type == type) {
        advance();
        return 1;
    }
    parse_error = 1;
    snprintf(parse_error_msg, 256, "Expected %s but got %s ('%s') at line %d, col %d",
        token_type_name(type), token_type_name(current_token()->type),
        current_token()->value, current_token()->line, current_token()->col);
    return 0;
}

// E -> E + T | E - T | T  (left recursive - we use iterative)
static void parse_expr(char* tree, int depth) {
    if (parse_error) return;
    indent(tree, depth);
    strcat(tree, "Expr\\n");
    parse_term(tree, depth + 1);
    while (!parse_error && (current_token()->type == TOK_PLUS || current_token()->type == TOK_MINUS)) {
        indent(tree, depth + 1);
        char buf[32];
        snprintf(buf, 32, "Op: %s\\n", current_token()->value);
        strcat(tree, buf);
        advance();
        parse_term(tree, depth + 1);
    }
}

// T -> T * F | T / F | F  (left recursive - we use iterative)
static void parse_term(char* tree, int depth) {
    if (parse_error) return;
    indent(tree, depth);
    strcat(tree, "Term\\n");
    parse_factor(tree, depth + 1);
    while (!parse_error && (current_token()->type == TOK_STAR || current_token()->type == TOK_SLASH)) {
        indent(tree, depth + 1);
        char buf[32];
        snprintf(buf, 32, "Op: %s\\n", current_token()->value);
        strcat(tree, buf);
        advance();
        parse_factor(tree, depth + 1);
    }
}

// F -> ( E ) | id | number
static void parse_factor(char* tree, int depth) {
    if (parse_error) return;
    indent(tree, depth);
    strcat(tree, "Factor\\n");

    if (current_token()->type == TOK_LPAREN) {
        indent(tree, depth + 1);
        strcat(tree, "(\\n");
        advance();
        parse_expr(tree, depth + 1);
        if (!parse_error) {
            indent(tree, depth + 1);
            strcat(tree, ")\\n");
            expect(TOK_RPAREN);
        }
    } else if (current_token()->type == TOK_IDENTIFIER) {
        indent(tree, depth + 1);
        char buf[80];
        snprintf(buf, 80, "ID: %s\\n", current_token()->value);
        strcat(tree, buf);
        advance();
    } else if (current_token()->type == TOK_NUMBER || current_token()->type == TOK_FLOAT_LIT) {
        indent(tree, depth + 1);
        char buf[80];
        snprintf(buf, 80, "NUM: %s\\n", current_token()->value);
        strcat(tree, buf);
        advance();
    } else {
        parse_error = 1;
        snprintf(parse_error_msg, 256, "Unexpected token '%s' (%s) at line %d, col %d",
            current_token()->value, token_type_name(current_token()->type),
            current_token()->line, current_token()->col);
    }
}

// Parse a statement: [type] id = expr ;
static void parse_statement(char* tree) {
    indent(tree, 0);
    strcat(tree, "Statement\\n");

    // Optional type
    if (current_token()->type == TOK_INT || current_token()->type == TOK_FLOAT || current_token()->type == TOK_CHAR) {
        indent(tree, 1);
        char buf[80];
        snprintf(buf, 80, "Type: %s\\n", current_token()->value);
        strcat(tree, buf);
        advance();
    }

    if (current_token()->type == TOK_IDENTIFIER) {
        Token* id_tok = current_token();
        // Check if assignment
        if (parse_pos + 1 < token_count && tokens[parse_pos + 1].type == TOK_ASSIGN) {
            indent(tree, 1);
            char buf[80];
            snprintf(buf, 80, "ID: %s\\n", id_tok->value);
            strcat(tree, buf);
            advance(); // skip id
            indent(tree, 1);
            strcat(tree, "=\\n");
            advance(); // skip =
            parse_expr(tree, 1);
        } else {
            parse_expr(tree, 1);
        }
    } else {
        parse_expr(tree, 1);
    }

    if (!parse_error && current_token()->type == TOK_SEMICOLON) {
        indent(tree, 1);
        strcat(tree, ";\\n");
        advance();
    }
}

// ==================== SEMANTIC ANALYSIS ====================

typedef struct {
    char name[MAX_TOKEN_LEN];
    char type[16]; // "int", "float", "char"
    int initialized;
} Symbol;

#define MAX_SYMBOLS 64
static Symbol symbol_table[MAX_SYMBOLS];
static int symbol_count = 0;

static int find_symbol(const char* name) {
    for (int i = 0; i < symbol_count; i++) {
        if (strcmp(symbol_table[i].name, name) == 0) return i;
    }
    return -1;
}

static void add_symbol(const char* name, const char* type, int init) {
    if (symbol_count < MAX_SYMBOLS) {
        strncpy(symbol_table[symbol_count].name, name, MAX_TOKEN_LEN - 1);
        strncpy(symbol_table[symbol_count].type, type, 15);
        symbol_table[symbol_count].initialized = init;
        symbol_count++;
    }
}

// ==================== EXPORTED FUNCTIONS ====================

EMSCRIPTEN_KEEPALIVE
const char* do_lexical_analysis(const char* input) {
    char struct_error[256];
    if (!verify_c_structure(input, struct_error)) {
        // Return a structural error as a special single element token JSON payload
        snprintf(output_buffer, MAX_OUTPUT, "[{\"type\":\"ERROR\",\"value\":\"%s\",\"line\":1,\"col\":1}]", struct_error);
        return output_buffer;
    }

    lexer(input);

    strcpy(output_buffer, "[");
    for (int i = 0; i < token_count; i++) {
        char entry[256];
        snprintf(entry, 256,
            "%s{\"type\":\"%s\",\"value\":\"%s\",\"line\":%d,\"col\":%d}",
            (i > 0 ? "," : ""),
            token_type_name(tokens[i].type),
            tokens[i].value,
            tokens[i].line,
            tokens[i].col);
        strcat(output_buffer, entry);
    }
    strcat(output_buffer, "]");
    return output_buffer;
}

EMSCRIPTEN_KEEPALIVE
const char* do_syntax_analysis(const char* input) {
    // Run the lexer on the inner statement strings passed from the frontend
    lexer(input);

    parse_pos = 0;
    parse_error = 0;
    parse_error_msg[0] = '\0';

    char tree[4096];
    tree[0] = '\0';

    // Global analysis iterator loop
    while (!parse_error && current_token()->type != TOK_EOF) {
        
        // --- RULE 1: Skip Control Structure Keywords & Condition Blocks ---
        // Handles: while, if, else, for, switch, etc.
        if (current_token()->type == TOK_WHILE || current_token()->type == TOK_IF || current_token()->type == TOK_ELSE) {
            advance(); // Skip keyword
            
            // If the keyword is followed by a condition group (e.g., "(x < 5)"), skip the whole group
            if (current_token()->type == TOK_LPAREN) {
                int paren_depth = 1;
                advance();
                while (paren_depth > 0 && current_token()->type != TOK_EOF) {
                    if (current_token()->type == TOK_LPAREN) paren_depth++;
                    if (current_token()->type == TOK_RPAREN) paren_depth--;
                    advance();
                }
            }
            continue;
        }

        // --- RULE 2: Skip Function Calls & Standard Identifiers without Assignments ---
        // Handles: printf("..."), custom_func(a, b), return 0;
        if (current_token()->type == TOK_IDENTIFIER || strcmp(current_token()->value, "return") == 0) {
            Token* id_token = current_token();
            
            // Check if this identifier is just a variable assignment (e.g., x = 5)
            // If it IS an assignment, break out of this rule and let parse_statement() handle it!
            bool is_assignment = false;
            if (parse_pos + 1 < token_count && tokens[parse_pos + 1].type == TOK_ASSIGN) {
                is_assignment = true;
            }
            
            if (!is_assignment) {
                advance(); // Skip identifier or return keyword
                
                // If it's a function invocation, skip until its closing parenthesis ')'
                if (current_token()->type == TOK_LPAREN) {
                    int paren_depth = 1;
                    advance();
                    while (paren_depth > 0 && current_token()->type != TOK_EOF) {
                        if (current_token()->type == TOK_LPAREN) paren_depth++;
                        if (current_token()->type == TOK_RPAREN) paren_depth--;
                        advance();
                    }
                }
                
                // Advance past any trailing statement terminators
                if (current_token()->type == TOK_SEMICOLON) {
                    advance();
                }
                continue;
            }
        }

        // --- RULE 3: Skip Block Scope Layout Braces ---
        // Handles: '{' and '}' structural wrappers globally
        if (current_token()->type == TOK_LBRACE || current_token()->type == TOK_RBRACE) {
            advance();
            continue;
        }

        // --- RULE 4: Parse Math & Expression Statements ---
        // If the current token doesn't match a structural block, it is parsed 
        // using your grammar rule equations (e.g., type declarations or assignments)
        parse_statement(tree);
    }

    snprintf(output_buffer, MAX_OUTPUT,
        "{\"success\":%s,\"error\":\"%s\",\"parseTree\":\"%s\","
        \"grammar\":{"
        \"rules\":["
        "{\"name\":\"E → E + T | E - T | T\",\"leftRecursive\":true,\"rightRecursive\":false},"
        "{\"name\":\"T → T * F | T / F | F\",\"leftRecursive\":true,\"rightRecursive\":false},"
        "{\"name\":\"F → ( E ) | id | num\",\"leftRecursive\":false,\"rightRecursive\":false}"
        "],"
        \"isAmbiguous\":false,"
        \"ambiguityReason\":\"Operator precedence (* binds tighter than +) and left-associativity remove ambiguity.\","
        \"hasLeftRecursion\":true,"
        \"leftRecursionDetail\":\"E → E + T and T → T * F are left recursive. Handled by iterative parsing (equivalent to left-recursion elimination).\","
        \"hasRightRecursion\":false"
        "}}",
        parse_error ? "false" : "true",
        parse_error ? parse_error_msg : "",
        tree);

    return output_buffer;
}

EMSCRIPTEN_KEEPALIVE
const char* do_semantic_analysis(const char* input) {
    char struct_error[256];
    if (!verify_c_structure(input, struct_error)) {
        snprintf(output_buffer, MAX_OUTPUT, 
            "{\"success\":false,\"checks\":[{\"check\":\"Structural Check\",\"message\":\"%s\",\"pass\":false,\"line\":1}],\"symbolTable\":[]}", 
            struct_error);
        return output_buffer;
    }

    lexer(input);
    symbol_count = 0;

    char checks[4096];
    strcpy(checks, "[");
    int check_count = 0;
    int has_error = 0;

    // Walk through tokens doing semantic checks
    int i = 0;
    while (i < token_count && tokens[i].type != TOK_EOF) {
        // Declaration: type id = expr ;
        if (tokens[i].type == TOK_INT || tokens[i].type == TOK_FLOAT || tokens[i].type == TOK_CHAR) {
            const char* type_name = tokens[i].value;
            i++;
            if (i < token_count && tokens[i].type == TOK_IDENTIFIER) {
                const char* var_name = tokens[i].value;

                // Check for redeclaration
                if (find_symbol(var_name) >= 0) {
                    char buf[512];
                    snprintf(buf, 512, "%s{\"check\":\"Redeclaration\",\"message\":\"Variable '%s' is already declared\",\"pass\":false,\"line\":%d}",
                        check_count > 0 ? "," : "", var_name, tokens[i].line);
                    strcat(checks, buf);
                    check_count++;
                    has_error = 1;
                } else {
                    int init = 0;
                    // Check if initialized
                    if (i + 1 < token_count && tokens[i + 1].type == TOK_ASSIGN) {
                        init = 1;
                    }
                    add_symbol(var_name, type_name, init);

                    char buf[512];
                    snprintf(buf, 512, "%s{\"check\":\"Declaration\",\"message\":\"Variable '%s' declared as '%s'%s\",\"pass\":true,\"line\":%d}",
                        check_count > 0 ? "," : "", var_name, type_name, init ? " and initialized" : "", tokens[i].line);
                    strcat(checks, buf);
                    check_count++;
                }

                // Type checking on assignment
                if (i + 1 < token_count && tokens[i + 1].type == TOK_ASSIGN) {
                    i += 2; // skip id and =
                    // Check RHS types
                    while (i < token_count && tokens[i].type != TOK_SEMICOLON && tokens[i].type != TOK_EOF) {
                        if (tokens[i].type == TOK_IDENTIFIER) {
                            int sym_idx = find_symbol(tokens[i].value);
                            if (sym_idx < 0) {
                                char buf[512];
                                snprintf(buf, 512, "%s{\"check\":\"Undeclared Variable\",\"message\":\"Variable '%s' used but not declared\",\"pass\":false,\"line\":%d}",
                                    check_count > 0 ? "," : "", tokens[i].value, tokens[i].line);
                                strcat(checks, buf);
                                check_count++;
                                has_error = 1;
                            } else if (!symbol_table[sym_idx].initialized) {
                                char buf[512];
                                snprintf(buf, 512, "%s{\"check\":\"Uninitialized Variable\",\"message\":\"Variable '%s' used before initialization\",\"pass\":false,\"line\":%d}",
                                    check_count > 0 ? "," : "", tokens[i].value, tokens[i].line);
                                strcat(checks, buf);
                                check_count++;
                                has_error = 1;
                            } else {
                                // Type compatibility check
                                if (strcmp(type_name, "int") == 0 && strcmp(symbol_table[sym_idx].type, "float") == 0) {
                                    char buf[512];
                                    snprintf(buf, 512, "%s{\"check\":\"Type Mismatch Warning\",\"message\":\"Assigning float '%s' to int variable (possible precision loss)\",\"pass\":false,\"line\":%d}",
                                        check_count > 0 ? "," : "", tokens[i].value, tokens[i].line);
                                    strcat(checks, buf);
                                    check_count++;
                                }
                            }
                        }
                        // Division by zero check
                        if (tokens[i].type == TOK_SLASH && i + 1 < token_count &&
                            tokens[i+1].type == TOK_NUMBER && strcmp(tokens[i+1].value, "0") == 0) {
                            char buf[256];
                            snprintf(buf, 256, "%s{\"check\":\"Division by Zero\",\"message\":\"Division by zero detected\",\"pass\":false,\"line\":%d}",
                                check_count > 0 ? "," : "", tokens[i].line);
                            strcpy(checks + strlen(checks), buf);
                            check_count++;
                            has_error = 1;
                        }
                        i++;
                    }
                } else {
                    i++;
                }
            }
        }
        // Usage without declaration
        else if (tokens[i].type == TOK_IDENTIFIER) {
            if (i + 1 < token_count && tokens[i + 1].type == TOK_ASSIGN) {
                if (find_symbol(tokens[i].value) < 0) {
                    char buf[512];
                    snprintf(buf, 512, "%s{\"check\":\"Undeclared Variable\",\"message\":\"Variable '%s' assigned but not declared\",\"pass\":false,\"line\":%d}",
                        check_count > 0 ? "," : "", tokens[i].value, tokens[i].line);
                    strcat(checks, buf);
                    check_count++;
                    has_error = 1;
                }
            }
            i++;
        }
        else {
            i++;
        }
    }

    // Add symbol table to output
    strcat(checks, "]");

    char sym_table[2048];
    strcpy(sym_table, "[");
    for (int s = 0; s < symbol_count; s++) {
        char buf[256];
        snprintf(buf, 256, "%s{\"name\":\"%s\",\"type\":\"%s\",\"initialized\":%s}",
            s > 0 ? "," : "",
            symbol_table[s].name,
            symbol_table[s].type,
            symbol_table[s].initialized ? "true" : "false");
        strcat(sym_table, buf);
    }
    strcat(sym_table, "]");

    snprintf(output_buffer, MAX_OUTPUT,
        "{\"success\":%s,\"checks\":%s,\"symbolTable\":%s}",
        has_error ? "false" : "true",
        checks, sym_table);

    return output_buffer;
}
